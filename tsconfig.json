{
  "compilerOptions": {
    /* Core */
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "es2020"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    /* Strictness */
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    /* Performance */
    "skipLibCheck": true,
    "incremental": true,
    "isolatedModules": true,
    /* Interop */
    "esModuleInterop": true,
    "resolveJsonModule": true,
    /* Next.js Plugin */
    "plugins": [
      {
        "name": "next"
      }
    ],
    /* Aliases (no baseUrl needed) */
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    /* Types */
    "types": [
      "node"
    ],
    /* Output */
    "noEmit": true,
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
